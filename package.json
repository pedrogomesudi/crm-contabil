{
  "name": "crm-contabil",
  "version": "6.16.0",
  "private": true,
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "release:tag": "node scripts/release-tag.mjs",
    "db:migrate": "node --env-file=.env.local scripts/db-migrate.mjs",
    "db:test": "node --env-file=.env.local scripts/db-test-rls.mjs",
    "admin:bootstrap": "node --env-file=.env.local scripts/bootstrap-admin.mjs",
    "cron:bootstrap": "node --env-file=.env.local scripts/bootstrap-cron.mjs",
    "tenant:novo": "node scripts/tenant-novo.mjs",
    "tenant:adotar": "node scripts/tenant-adotar.mjs",
    "tenant:doctor": "node scripts/tenant-doctor.mjs",
    "db:migrate:all": "node scripts/tenants-all.mjs db-migrate",
    "db:test:all": "node scripts/tenants-all.mjs db-test-rls",
    "cron:bootstrap:all": "node scripts/tenants-all.mjs bootstrap-cron",
    "cripto:migrar": "node --env-file=.env.local scripts/cripto-migrar.mjs",
    "cripto:rotacionar": "node --env-file=.env.local scripts/cripto-rotacionar.mjs",
    "backup:dump": "node scripts/backup-dump.mjs",
    "restore:verificar": "node scripts/restore-verificar.mjs",
    "backup:agendar": "node scripts/agendar-backup.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "0.12.0",
    "@supabase/supabase-js": "2.108.2",
    "cfb": "^1.2.2",
    "docxtemplater": "^3.69.0",
    "exceljs": "^4.4.0",
    "extenso": "^2.1.0",
    "fast-xml-parser": "^5.9.3",
    "next": "16.2.9",
    "node-forge": "^1.4.0",
    "nodemailer": "^9.0.3",
    "pizzip": "^3.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "xml-crypto": "^6.1.2",
    "xmlbuilder2": "^4.0.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22.20.0",
    "@types/node-forge": "^1.3.14",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "jsdom": "^29.1.1",
    "pg": "^8.22.0",
    "prettier": "^3.8.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
