# URL pública do app (usada em metadataBase). Em produção, o domínio do EasyPanel.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# O .env.local aponta para o projeto de DESENVOLVIMENTO (`saldo-dev`) — nunca para
# produção, que vive noutro projeto Supabase e tem os segredos no painel do EasyPanel.
# Os dois já compartilharam o mesmo banco: um erro em dev acertava cliente real.

# Supabase (build-time — embutidas no bundle)
# ANON_KEY: usar a "Publishable key" (formato novo sb_publishable_...); a anon
# JWT legada é rejeitada (401) neste projeto.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service_role (runtime — segredo, só no servidor)
SUPABASE_SERVICE_ROLE_KEY=

# Conexão direta ao Postgres (migrations/testes locais via scripts/db-*.mjs).
# Pegue em: Supabase → Connect → Session pooler (URI). URL-encode caracteres
# especiais da senha (ex.: # vira %23).
SUPABASE_DB_URL=

# (opcional) Caminho da CA do Supabase p/ os scripts de banco. Default: supabase/db-ca.crt
# SUPABASE_DB_CA=supabase/db-ca.crt

# Bootstrap do primeiro Admin (usado só por `npm run admin:bootstrap`).
# IMPORTANTE: use uma ADMIN_PASSWORD DIFERENTE da senha do Postgres. Após o
# primeiro login, troque a senha e REMOVA estas 3 variáveis do .env.local.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NOME=

# URL interna do serviço Gotenberg (docx -> pdf) para a geração de contrato (V3).
# Vazio = gera só o Word (degradação graciosa). Ex.: http://gotenberg:3000
GOTENBERG_URL=

# Clicksign (V4 — assinatura digital). Segredos runtime, só no servidor.
CLICKSIGN_URL=https://sandbox.clicksign.com/api/v3
CLICKSIGN_TOKEN=
CLICKSIGN_HMAC_SECRET=

# NFS-e nacional (V5). Segredos runtime, só no servidor.
NFSE_AMBIENTE=homologacao
NFSE_URL_HOMOLOGACAO=https://sefin.producaorestrita.nfse.gov.br/API/SefinNacional
NFSE_URL_PRODUCAO=https://sefin.nfse.gov.br/SefinNacional
NFSE_CERT_KEY=            # 32 bytes em hex (gerar: openssl rand -hex 32)

# Envelope encryption (V10-B). A mestra cifra as 5 DEKs em `chave_dados`; cada chave de
# domínio é o valor da DEK. Gerar cada uma: openssl rand -hex 32.
# NUNCA reaproveite as chaves de produção aqui — seriam um erro de dev decifrando dado real.
# Depois de preencher, rode `npm run cripto:migrar` (é ele que grava as DEKs; a migration
# 0097 cria a tabela vazia, e sem esse passo as features cifradas quebram).
MASTER_CRIPTO_KEY=
WHATSAPP_CRIPTO_KEY=
ONBOARDING_CRIPTO_KEY=
BOLETO_CRIPTO_KEY=
# Segredo do webhook de baixa de boleto. O provedor (Inter/Asaas) chama
# https://<APP_URL>/api/webhooks/boleto/<BOLETO_WEBHOOK_SECRET>. Gere com: openssl rand -hex 32
BOLETO_WEBHOOK_SECRET=
EMAIL_CRIPTO_KEY=

# Segredo dos endpoints chamados pelo pg_cron. openssl rand -hex 32.
CRON_SECRET=
