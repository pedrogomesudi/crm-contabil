# URL pública do app (usada em metadataBase). Em produção, o domínio do EasyPanel.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (build-time — embutidas no bundle)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service_role (runtime — segredo, só no servidor)
SUPABASE_SERVICE_ROLE_KEY=

# Conexão direta ao Postgres (migrations/testes locais via scripts/db-*.mjs).
# Pegue em: Supabase → Connect → Session pooler (URI). URL-encode caracteres
# especiais da senha (ex.: # vira %23).
SUPABASE_DB_URL=

# (opcional) Caminho da CA do Supabase p/ os scripts de banco. Default: supabase/db-ca.crt
# SUPABASE_DB_CA=supabase/db-ca.crt

# Bootstrap do primeiro Admin (usado só por `npm run admin:bootstrap`).
# IMPORTANTE: use uma ADMIN_PASSWORD DIFERENTE da senha do Postgres. Após o
# primeiro login, troque a senha e REMOVA estas 3 variáveis do .env.local.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NOME=
