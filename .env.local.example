# URL pública do app (usada em metadataBase). Em produção, o domínio do EasyPanel.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (build-time — embutidas no bundle)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service_role (runtime — segredo, só no servidor)
SUPABASE_SERVICE_ROLE_KEY=

# Conexão direta ao Postgres (migrations/testes locais via scripts/db-*.mjs).
# Pegue em: Supabase → Connect → Session pooler (URI). URL-encode caracteres
# especiais da senha (ex.: # vira %23).
SUPABASE_DB_URL=
