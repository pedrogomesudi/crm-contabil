# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.playwright-mcp/
.superpowers/

# Credenciais por escritório (multi-tenant, um banco por escritório). NUNCA versionar:
# uma service_role commitada não se desfaz — a chave já esteve lá e teria de ser rotacionada.
/tenants/*.env

# Backups locais (contêm dado de cliente) — NUNCA versionar.
/backups/
